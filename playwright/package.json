{
    "name": "genai-ecom-playwright",
    "version": "1.0.0",
    "description": "Playwright tests for genai_training ecommerce store",
    "scripts": {
        "test": "npx playwright test",
        "test:ui": "npx playwright test --ui",
        "test:headed": "npx playwright test --headed",
        "test:smoke": "npx playwright test --project=smoke",
        "test:regression": "npx playwright test --project=regression",
        "lint": "node scripts/lint.js",
        "test:unit": "node --test --test-reporter=spec --test-reporter-destination=stdout --test-reporter=junit --test-reporter-destination=unit-results.xml tests/unit/utils.test.js"
    },
    "devDependencies": {
        "@playwright/test": "^1.40.0"
    }
}